{
  "name": "rahasya-video-generation",
  "version": "1.0.0",
  "description": "Generates short-form vertical (9:16) MP4 videos from Rahasya marketing_content rows. Zero native dependencies — pure Node.js + TypeScript + FFmpeg drawtext. Designed for GitHub Actions.",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "generate": "ts-node src/commands/generateVideos.ts",
    "test-video": "ts-node src/commands/generateVideos.ts --limit=1",
    "preview": "ts-node src/commands/preview.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "setup:piper": "bash scripts/setup-piper.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/yargs": "^17.0.32",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
