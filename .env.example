# --- Supabase ---------------------------------------------------------
# Project URL, e.g. https://xxxxx.supabase.co
SUPABASE_URL=

# Service role key (NOT the anon key). Required because this worker
# reads marketing_content, writes social_videos, and uploads to a
# storage bucket — all of which need elevated privileges.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket that videos are uploaded to. Created by sql/001_social_videos.sql
# instructions / Supabase dashboard. Defaults to "social-videos".
SUPABASE_VIDEO_BUCKET=social-videos

# --- FFmpeg -------------------------------------------------------------
# Path to the ffmpeg / ffprobe binaries. Defaults to "ffmpeg" / "ffprobe"
# (i.e. resolved from PATH). Override if you vendor a static binary.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- Assets ---------------------------------------------------------
# Reusable background loop (vertical, ideally >= 1080x1920) and ambient
# music bed. See assets/README.md — if these are missing, the pipeline
# falls back to a generated placeholder so `npm run preview` still works.
BACKGROUND_VIDEO_PATH=assets/background.mp4
MUSIC_TRACK_PATH=assets/music.mp3

# --- Branding ---------------------------------------------------------
BRAND_NAME=Rahasya
BRAND_URL=discover-rahasya.vercel.app

# --- Processing ---------------------------------------------------------
# Default batch size when no --limit is passed to `npm run generate`
DEFAULT_BATCH_LIMIT=20

# Local working directories
TMP_DIR=tmp
OUTPUT_DIR=output
