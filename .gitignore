# Dependencies
node_modules/

# Build output
dist/

# Environment — never commit real credentials
.env

# Runtime working directories
tmp/
output/

# Piper TTS — installed automatically by scripts/setup-piper.sh, never committed
.piper-bin/
assets/voice/*.onnx
assets/voice/*.onnx.json

# Large binary assets — store in S3 / LFS, download in CI
assets/*.mp4
assets/*.mp3
assets/fonts/*.ttf
assets/fonts/*.otf

# OS noise
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
